<div class="d-flex justify-content-between align-items-center mb-4">
  <h2 class="mb-0"><%= proveedor ? 'Editar' : 'Nuevo' %> Proveedor</h2>
  <a href="/proveedores" class="btn btn-outline-secondary"><i data-lucide="arrow-left" class="me-1"></i> Volver</a>
</div>
<% if (typeof error !== 'undefined' && error) { %>
  <div class="alert alert-danger alert-dismissible fade show" role="alert"><%= error %><button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
<% } %>
<div class="card shadow-sm">
  <div class="card-body">
    <form method="POST" action="<%= proveedor ? '/proveedores/editar/' + proveedor.proveedor_id : '/proveedores' %>">
      <div class="row g-3">
        <div class="col-md-6">
          <label for="nombre" class="form-label">Nombre <span class="text-danger">*</span></label>
          <input type="text" class="form-control" id="nombre" name="nombre" required value="<%= proveedor ? proveedor.nombre : '' %>" maxlength="50">
        </div>
        <div class="col-md-6">
          <label for="contacto" class="form-label">Contacto</label>
          <input type="text" class="form-control" id="contacto" name="contacto" value="<%= proveedor ? (proveedor.contacto || '') : '' %>" maxlength="50">
        </div>
        <div class="col-md-6">
          <label for="telefono" class="form-label">Teléfono</label>
          <input type="text" class="form-control" id="telefono" name="telefono" value="<%= proveedor ? (proveedor.telefono || '') : '' %>" maxlength="15">
        </div>
        <div class="col-md-6">
          <label for="email" class="form-label">Email</label>
          <input type="email" class="form-control" id="email" name="email" value="<%= proveedor ? (proveedor.email || '') : '' %>" maxlength="100">
        </div>
        <div class="col-12">
          <label for="direccion" class="form-label">Dirección</label>
          <input type="text" class="form-control" id="direccion" name="direccion" value="<%= proveedor ? (proveedor.direccion || '') : '' %>">
        </div>
        <div class="col-12">
          <button type="submit" class="btn btn-primary"><i data-lucide="save" class="me-1"></i><%= proveedor ? 'Guardar' : 'Crear' %></button>
          <a href="/proveedores" class="btn btn-outline-secondary ms-2">Cancelar</a>
        </div>
      </div>
    </form>
  </div>
</div>
<script>lucide.createIcons();</script>
