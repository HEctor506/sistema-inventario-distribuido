<div class="d-flex justify-content-between align-items-center mb-4">
  <h2 class="mb-0">Reportes de Inventario</h2>
</div>

<div class="card shadow-sm mb-4">
  <div class="card-body">
    <h6 class="mb-3">Rango de fechas para reportes basados en movimientos</h6>
    <form method="GET" action="/reportes/dashboard" class="row g-2 align-items-end">
      <div class="col-md-3">
        <label class="form-label mb-0 small">Fecha inicio</label>
        <input type="date" class="form-control form-control-sm" name="fecha_inicio"
               value="<%= filtros && filtros.fecha_inicio ? filtros.fecha_inicio : '' %>">
      </div>
      <div class="col-md-3">
        <label class="form-label mb-0 small">Fecha fin</label>
        <input type="date" class="form-control form-control-sm" name="fecha_fin"
               value="<%= filtros && filtros.fecha_fin ? filtros.fecha_fin : '' %>">
      </div>
      <div class="col-md-2">
        <button type="submit" class="btn btn-primary btn-sm w-100">
          <i data-lucide="refresh-cw" class="me-1"></i> Actualizar
        </button>
      </div>
    </form>
  </div>
</div>

<div class="row g-3 mb-3">
  <div class="col-md-6">
    <div class="card shadow-sm h-100">
      <div class="card-body">
        <h5 class="mb-3 d-flex align-items-center">
          <i data-lucide="alert-triangle" class="me-2 text-warning"></i>
          Productos con stock bajo
        </h5>
        <div class="table-responsive">
          <table class="table table-sm table-hover mb-0">
            <thead class="table-light">
              <tr>
                <th>ID</th>
                <th>Nombre</th>
                <th>Stock</th>
                <th>Mínimo</th>
              </tr>
            </thead>
            <tbody>
              <% if (!stockBajo || stockBajo.length === 0) { %>
                <tr>
                  <td colspan="4" class="text-center text-muted py-3">No hay productos con stock bajo.</td>
                </tr>
              <% } else { %>
                <% stockBajo.forEach(p => { %>
                  <tr class="table-warning">
                    <td><%= p.producto_id %></td>
                    <td><%= p.nombre %></td>
                    <td><%= p.stock_actual %></td>
                    <td><%= p.stock_minimo %></td>
                  </tr>
                <% }) %>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>

  <div class="col-md-6">
    <div class="card shadow-sm h-100">
      <div class="card-body">
        <h5 class="mb-3 d-flex align-items-center">
          <i data-lucide="activity" class="me-2 text-primary"></i>
          Top 10 productos más movidos
        </h5>
        <div class="table-responsive">
          <table class="table table-sm table-hover mb-0">
            <thead class="table-light">
              <tr>
                <th>#</th>
                <th>Producto</th>
                <th>Total salidas</th>
              </tr>
            </thead>
            <tbody>
              <% if (!topMovidos || topMovidos.length === 0) { %>
                <tr>
                  <td colspan="3" class="text-center text-muted py-3">Sin datos para el rango seleccionado.</td>
                </tr>
              <% } else { %>
                <% topMovidos.forEach((r, idx) => { %>
                  <tr>
                    <td><%= idx + 1 %></td>
                    <td><%= r.nombre %></td>
                    <td><%= r.total_salidas %></td>
                  </tr>
                <% }) %>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="row g-3 mb-3">
  <div class="col-md-6">
    <div class="card shadow-sm h-100">
      <div class="card-body">
        <h5 class="mb-3 d-flex align-items-center">
          <i data-lucide="layers" class="me-2 text-success"></i>
          Valor total del inventario por categoría
        </h5>
        <div class="table-responsive">
          <table class="table table-sm table-hover mb-0">
            <thead class="table-light">
              <tr>
                <th>Categoría</th>
                <th class="text-end">Valor total</th>
              </tr>
            </thead>
            <tbody>
              <% if (!valorInventario || valorInventario.length === 0) { %>
                <tr>
                  <td colspan="2" class="text-center text-muted py-3">Sin datos disponibles.</td>
                </tr>
              <% } else { %>
                <% valorInventario.forEach(r => { %>
                  <tr>
                    <td><%= r.categoria %></td>
                    <td class="text-end">
                      $<%= parseFloat(r.valor_total || 0).toLocaleString('es-EC', { minimumFractionDigits: 2 }) %>
                    </td>
                  </tr>
                <% }) %>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>

  <div class="col-md-6">
    <div class="card shadow-sm h-100">
      <div class="card-body">
        <h5 class="mb-3 d-flex align-items-center">
          <i data-lucide="truck" class="me-2 text-info"></i>
          Resumen por proveedor
        </h5>
        <div class="table-responsive">
          <table class="table table-sm table-hover mb-0">
            <thead class="table-light">
              <tr>
                <th>Proveedor</th>
                <th class="text-center">Productos</th>
                <th class="text-end">Valor total</th>
              </tr>
            </thead>
            <tbody>
              <% if (!resumenProveedor || resumenProveedor.length === 0) { %>
                <tr>
                  <td colspan="3" class="text-center text-muted py-3">Sin datos disponibles.</td>
                </tr>
              <% } else { %>
                <% resumenProveedor.forEach(r => { %>
                  <tr>
                    <td><%= r.nombre %></td>
                    <td class="text-center"><%= r.total_productos %></td>
                    <td class="text-end">
                      $<%= parseFloat(r.valor_total || 0).toLocaleString('es-EC', { minimumFractionDigits: 2 }) %>
                    </td>
                  </tr>
                <% }) %>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="card shadow-sm">
  <div class="card-body">
    <h5 class="mb-3 d-flex align-items-center">
      <i data-lucide="repeat" class="me-2 text-secondary"></i>
      Movimientos por fecha
    </h5>
    <div class="mb-2 small text-muted">
      Totales en rango:
      <span class="ms-2">Entradas: <strong><%= totalesMovimientos ? totalesMovimientos.totalEntradas : 0 %></strong></span>
      <span class="ms-2">Salidas: <strong><%= totalesMovimientos ? totalesMovimientos.totalSalidas : 0 %></strong></span>
      <span class="ms-2">Unidades movidas: <strong><%= totalesMovimientos ? totalesMovimientos.totalMovimientos : 0 %></strong></span>
    </div>
    <div class="table-responsive">
      <table class="table table-sm table-hover mb-0">
        <thead class="table-light">
          <tr>
            <th>ID</th>
            <th>Fecha</th>
            <th>Tipo</th>
            <th>Cantidad</th>
            <th>Producto</th>
            <th>Proveedor</th>
          </tr>
        </thead>
        <tbody>
          <% if (!movimientos || movimientos.length === 0) { %>
            <tr>
              <td colspan="6" class="text-center text-muted py-3">Sin movimientos para el rango seleccionado.</td>
            </tr>
          <% } else { %>
            <% movimientos.forEach(m => { %>
              <tr>
                <td><%= m.movimiento_id %></td>
                <td><%= new Date(m.fecha).toLocaleString('es-EC') %></td>
                <td>
                  <span class="badge <%= m.tipo === 'entrada' ? 'bg-success' : 'bg-danger' %>">
                    <%= m.tipo %>
                  </span>
                </td>
                <td><%= m.cantidad %></td>
                <td><%= m.producto_id %></td>
                <td><%= m.proveedor_id || '-' %></td>
              </tr>
            <% }) %>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<script>
  if (typeof lucide !== 'undefined') {
    lucide.createIcons();
  }
</script>