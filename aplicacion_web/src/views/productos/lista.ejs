<div class="d-flex justify-content-between align-items-center mb-4">
  <h2 class="mb-0">Productos</h2>
  <a href="/productos/crear" class="btn btn-primary">
    <i data-lucide="plus" class="me-1"></i> Nuevo Producto
  </a>
</div>

<% if (typeof productosStockBajo !== 'undefined' && productosStockBajo > 0) { %>
  <div class="alert alert-warning alert-dismissible fade show d-flex align-items-center" role="alert">
    <i data-lucide="alert-triangle" class="me-2"></i>
    <strong>Alerta:</strong> Tienes <strong><%= productosStockBajo %></strong> producto(s) con stock bajo o crítico.
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  </div>
<% } %>

<% if (typeof success !== 'undefined' && success) { %>
  <div class="alert alert-success alert-dismissible fade show" role="alert">
    <%= success %>
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  </div>
<% } %>
<% if (typeof error !== 'undefined' && error) { %>
  <div class="alert alert-danger alert-dismissible fade show" role="alert">
    <%= error %>
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  </div>
<% } %>

<div class="card shadow-sm mb-4">
  <div class="card-body">
    <h6 class="mb-3">Buscar Productos</h6>
    <form method="GET" action="/productos" class="row g-2 align-items-end">
      <div class="col-md-4">
        <label class="form-label mb-0 small">Nombre o descripción</label>
        <input type="text" class="form-control form-control-sm" name="buscar" placeholder="Buscar..." value="<%= filtros && filtros.buscar ? filtros.buscar : '' %>">
      </div>
      <div class="col-md-3">
        <label class="form-label mb-0 small">Categoría</label>
        <select class="form-select form-select-sm" name="categoria_id">
          <option value="">Todas</option>
          <% if (categorias) categorias.forEach(c => { %>
            <option value="<%= c.categoria_id %>" <%= filtros && filtros.categoria_id == c.categoria_id ? 'selected' : '' %>><%= c.nombre %></option>
          <% }) %>
        </select>
      </div>
      <div class="col-md-3">
        <label class="form-label mb-0 small">Proveedor</label>
        <select class="form-select form-select-sm" name="proveedor_id">
          <option value="">Todos</option>
          <% if (proveedores) proveedores.forEach(pr => { %>
            <option value="<%= pr.proveedor_id %>" <%= filtros && filtros.proveedor_id == pr.proveedor_id ? 'selected' : '' %>><%= pr.nombre %></option>
          <% }) %>
        </select>
      </div>
      <div class="col-md-2">
        <button type="submit" class="btn btn-primary btn-sm w-100"><i data-lucide="search"></i> Buscar</button>
        <a href="/productos" class="btn btn-outline-secondary btn-sm w-100 mt-1">Limpiar</a>
      </div>
    </form>
  </div>
</div>

<div class="card shadow-sm">
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-hover mb-0">
        <thead class="table-light">
          <tr>
            <th>ID</th>
            <th>Nombre</th>
            <th>Descripción</th>
            <th>Precio</th>
            <th>Stock</th>
            <th>Categoría</th>
            <th>Proveedor</th>
            <th class="text-end">Acciones</th>
          </tr>
        </thead>
        <tbody>
          <% if (!productos || productos.length === 0) { %>
            <tr>
              <td colspan="8" class="text-center text-muted py-4">No hay productos registrados</td>
            </tr>
          <% } else { %>
            <% productos.forEach(p => { %>
              <tr class="<%= p.stock_actual <= p.stock_minimo ? 'table-warning' : '' %>">
                <td><%= p.producto_id %></td>
                <td>
                  <%= p.nombre %>
                  <% if (p.stock_actual <= p.stock_minimo) { %>
                    <i data-lucide="alert-triangle" class="text-danger ms-1" style="width: 16px; height: 16px;"></i>
                  <% } %>
                </td>
                <td><%= p.descripcion || '-' %></td>
                <td>$<%= parseFloat(p.precio_unitario).toFixed(2) %></td>
                <td>
                  <% if (p.stock_actual <= p.stock_minimo) { %>
                    <span class="badge bg-danger"><i data-lucide="alert-circle" style="width: 12px; height: 12px;"></i> <%= p.stock_actual %> (mín: <%= p.stock_minimo %>)</span>
                  <% } else { %>
                    <span class="badge bg-success"><%= p.stock_actual %></span>
                  <% } %>
                </td>
                <td><%= p.categoria_nombre || '-' %></td>
                <td><%= p.proveedor_nombre || '-' %></td>
                <td class="text-end">
                  <a href="/productos/editar/<%= p.producto_id %>" class="btn btn-sm btn-outline-primary me-1">
                    <i data-lucide="pencil"></i>
                  </a>
                  <form action="/productos/eliminar/<%= p.producto_id %>" method="POST" class="d-inline" onsubmit="return confirm('¿Eliminar este producto?');">
                    <button type="submit" class="btn btn-sm btn-outline-danger">
                      <i data-lucide="trash-2"></i>
                    </button>
                  </form>
                </td>
              </tr>
            <% }) %>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<script>
  lucide.createIcons();
  // Recrear iconos después de que Bootstrap cierre las alertas
  document.addEventListener('DOMContentLoaded', function() {
    const alertCloseButtons = document.querySelectorAll('[data-bs-dismiss="alert"]');
    alertCloseButtons.forEach(btn => {
      btn.addEventListener('click', () => {
        setTimeout(() => lucide.createIcons(), 100);
      });
    });
  });
</script>
