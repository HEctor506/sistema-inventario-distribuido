<div class="d-flex justify-content-between align-items-center mb-4">
  <h2 class="mb-0"><%= producto ? 'Editar' : 'Nuevo' %> Producto</h2>
  <a href="/productos" class="btn btn-outline-secondary">
    <i data-lucide="arrow-left" class="me-1"></i> Volver
  </a>
</div>

<% if (typeof error !== 'undefined' && error) { %>
  <div class="alert alert-danger alert-dismissible fade show" role="alert">
    <%= error %>
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  </div>
<% } %>

<div class="card shadow-sm">
  <div class="card-body">
    <form method="POST" action="<%= producto ? '/productos/editar/' + producto.producto_id : '/productos' %>">
      <div class="row g-3">
        <div class="col-md-6">
          <label for="nombre" class="form-label">Nombre <span class="text-danger">*</span></label>
          <input type="text" class="form-control" id="nombre" name="nombre" required
            value="<%= producto ? producto.nombre : '' %>" maxlength="80">
        </div>
        <div class="col-md-6">
          <label for="precio_unitario" class="form-label">Precio unitario <span class="text-danger">*</span></label>
          <input type="number" step="0.01" min="0" class="form-control" id="precio_unitario" name="precio_unitario" required
            value="<%= producto ? producto.precio_unitario : '' %>">
        </div>
        <div class="col-12">
          <label for="descripcion" class="form-label">Descripción</label>
          <textarea class="form-control" id="descripcion" name="descripcion" rows="2"><%= producto ? (producto.descripcion || '') : '' %></textarea>
        </div>
        <div class="col-md-4">
          <label for="stock_actual" class="form-label">Stock actual <span class="text-danger">*</span></label>
          <input type="number" min="0" class="form-control" id="stock_actual" name="stock_actual" required
            value="<%= producto ? producto.stock_actual : '0' %>">
        </div>
        <div class="col-md-4">
          <label for="stock_minimo" class="form-label">Stock mínimo <span class="text-danger">*</span></label>
          <input type="number" min="0" class="form-control" id="stock_minimo" name="stock_minimo" required
            value="<%= producto ? producto.stock_minimo : '0' %>">
        </div>
        <div class="col-md-4">
          <label for="categoria_id" class="form-label">Categoría <span class="text-danger">*</span></label>
          <select class="form-select" id="categoria_id" name="categoria_id" required>
            <option value="">Seleccione...</option>
            <% categorias.forEach(c => { %>
              <option value="<%= c.categoria_id %>" <%= producto && producto.categoria_id == c.categoria_id ? 'selected' : '' %>>
                <%= c.nombre %>
              </option>
            <% }) %>
          </select>
        </div>
        <div class="col-md-6">
          <label for="proveedor_id" class="form-label">Proveedor <span class="text-danger">*</span></label>
          <select class="form-select" id="proveedor_id" name="proveedor_id" required>
            <option value="">Seleccione...</option>
            <% proveedores.forEach(pr => { %>
              <option value="<%= pr.proveedor_id %>" <%= producto && producto.proveedor_id == pr.proveedor_id ? 'selected' : '' %>>
                <%= pr.nombre %>
              </option>
            <% }) %>
          </select>
        </div>
        <div class="col-12 mt-3">
          <button type="submit" class="btn btn-primary">
            <i data-lucide="save" class="me-1"></i>
            <%= producto ? 'Guardar cambios' : 'Crear producto' %>
          </button>
          <a href="/productos" class="btn btn-outline-secondary ms-2">Cancelar</a>
        </div>
      </div>
    </form>
  </div>
</div>

<script>lucide.createIcons();</script>
